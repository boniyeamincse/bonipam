{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bonipam.io/schemas/policy_v1.json",
  "title": "Boni PAM Policy Schema v1",
  "type": "object",
  "required": ["schema_version", "rules", "default_effect"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "description": {
      "type": "string"
    },
    "default_effect": {
      "type": "string",
      "enum": ["allow", "deny"]
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["effect", "subjects", "resources", "actions"],
        "properties": {
          "id": { "type": "string" },
          "effect": {
            "type": "string",
            "enum": ["allow", "deny"]
          },
          "subjects": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "resources": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "actions": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["attribute", "operator", "value"],
              "properties": {
                "attribute": { "type": "string" },
                "operator": {
                  "type": "string",
                  "enum": ["eq", "neq", "gt", "gte", "lt", "lte", "in", "nin", "between"]
                },
                "value": { "type": ["string", "number", "boolean", "array"] }
              }
            }
          },
          "obligations": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
